{
  "name": "vold",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:app": "VITE_BUILD_TARGET=app vite",
    "dev:dashboard": "VITE_BUILD_TARGET=dashboard vite --port 5174",
    "build:app": "VITE_BUILD_TARGET=app tsc -b && VITE_BUILD_TARGET=app vite build --outDir dist/app",
    "build:dashboard": "VITE_BUILD_TARGET=dashboard tsc -b && VITE_BUILD_TARGET=dashboard vite build --outDir dist/dashboard",
    "build": "npm run build:app && npm run build:dashboard",
    "preview:app": "vite preview --outDir dist/app",
    "preview:dashboard": "vite preview --outDir dist/dashboard --port 5174",
    "lint": "eslint .",
    "db:setup": "npx tsx scripts/setup-database.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.96.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.574.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
